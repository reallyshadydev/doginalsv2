# Doginals environment configuration example
# Copy this file to `.env` and fill in your values.

# RPC settings for Dogecoin Core (used by Node app)
NODE_RPC_URL=http://127.0.0.1:22555
NODE_RPC_USER=your_rpc_user
NODE_RPC_PASS=your_rpc_password

# Network and fees
# Set to 'true' to use Dogecoin testnet
TESTNET=false
# Miner fee per KB in satoshis (default in code is 100000000). Adjust as needed.
FEE_PER_KB=100000000

# Optional settings
# Path to the wallet file created by this tool
WALLET=.wallet.json
# Port for the express server used for viewing inscriptions
SERVER_PORT=3000

# Python autoLargeFileMinter settings (optional)
# Uncomment and set if you plan to use autoLargeFileMinter.py
RPC_USER=your_rpc_user
RPC_PASSWORD=your_rpc_password
RPC_HOST=127.0.0.1
RPC_PORT=22555